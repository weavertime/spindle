{
  "name": "@weavertime/spindle-slides-core",
  "version": "0.3.0",
  "description": "Core presentation editor engine for Spindle Slides",
  "repository": {
    "type": "git",
    "url": "https://github.com/weavertime/spindle.git",
    "directory": "packages/slides-core"
  },
  "bugs": {
    "url": "https://github.com/weavertime/spindle/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./collab": {
      "import": "./dist/collab/index.esm.js",
      "require": "./dist/collab/index.js",
      "types": "./dist/collab/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .rollup.cache"
  },
  "keywords": [
    "slides",
    "presentation",
    "powerpoint",
    "editor"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@weavertime/spindle-shared": "^0.3.0",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-transform": "^1.8.0",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
