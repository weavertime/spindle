{
  "name": "@weavertime/spindle-transport-websocket",
  "version": "0.3.0",
  "description": "WebSocket-backed CollabProvider for Spindle collaboration",
  "repository": {
    "type": "git",
    "url": "https://github.com/weavertime/spindle.git",
    "directory": "packages/transport-websocket"
  },
  "bugs": {
    "url": "https://github.com/weavertime/spindle/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .rollup.cache"
  },
  "keywords": [
    "collaboration",
    "websocket",
    "yjs",
    "real-time"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@weavertime/spindle-shared": "^0.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.0",
    "jest": "^29.7.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
