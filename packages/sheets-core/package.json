{
  "name": "@pagent-libs/sheets-core",
  "version": "0.2.0",
  "description": "Core spreadsheet engine for pagent-sheets",
  "repository": {
    "type": "git",
    "url": "https://github.com/pagentapp/pagent-libs.git",
    "directory": "packages/sheets-core"
  },
  "bugs": {
    "url": "https://github.com/pagentapp/pagent-libs/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./collab": {
      "import": "./dist/collab/index.esm.js",
      "require": "./dist/collab/index.js",
      "types": "./dist/collab/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "spreadsheet",
    "sheet",
    "excel",
    "data-table"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pagent-libs/shared": "^0.2.0",
    "immer": "^10.0.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0"
  }
}
